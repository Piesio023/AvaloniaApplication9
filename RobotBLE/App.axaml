<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AvaloniaApplication1.App"
             RequestedThemeVariant="Default">

	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceInclude Source="avares://AvaloniaApplication1/Resources/ResourceDictionary1.axaml"/>
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Application.Resources>

	<Application.Styles>

		<FluentTheme>
			<FluentTheme.Palettes>
				<ColorPaletteResources x:Key="Light"
                                       Accent="#ff34854d"
                                       BaseHigh="Black"/>

				<ColorPaletteResources x:Key="Dark"
                                       Accent="#ff34854d"
                                       BaseHigh="White"/>
			</FluentTheme.Palettes>
		</FluentTheme>

		<StyleInclude Source="avares://AvaloniaApplication1/Styles/HeaderedContentControl.axaml"/>
		<StyleInclude Source="avares://AvaloniaApplication1/Styles/Command.axaml"/>

	</Application.Styles>

</Application>